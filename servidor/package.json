{
  "name": "nexusmedia-server",
  "version": "1.0.0",
  "description": "Motor de contenido NexusMedia — scraping y API REST",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "docker:build": "docker build -t nexus-server .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env -v nexus-data:/app/data --name nexus-server nexus-server"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "ISC",
  "dependencies": {
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1"
  }
}
