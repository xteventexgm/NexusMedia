# ── Servidor ──────────────────────────────────────────────────────────────
# Render inyecta PORT automáticamente. En local puedes usar 3000.
PORT=3000
# Alias legacy (Electron local). PORT tiene prioridad.
# NEXUS_API_PORT=3000

# Escuchar en todas las interfaces (requerido para Docker/Render)
HOST=0.0.0.0

NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────
# Uso personal: * permite WebOS, Electron, Android y navegadores.
# Producción restrictiva: https://tu-app.onrender.com,http://localhost:5173
CORS_ORIGIN=*

# ── TMDB (enriquecimiento de metadatos — opcional) ───────────────────────
# Obtén credenciales en https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_READ_TOKEN=

# ── Datos persistentes (caché TV, etc.) ───────────────────────────────────
# En Docker/Render usa un path escribible o monta un volumen en este directorio.
NEXUS_DATA_DIR=./data

# ── Timeouts y caché ──────────────────────────────────────────────────────
HTTP_TIMEOUT_MS=20000
HOME_CACHE_TTL_MS=300000
TV_CACHE_TTL_MS=43200000

# ── DoramasFlix (relay Cloudflare Worker) ─────────────────────────────────
# DORAMASFLIX_RELAY_URL=https://TU-WORKER.workers.dev
# DORAMASFLIX_RELAY_KEY=   (opcional; tu Worker actual no lo usa)

# ── PelisplusHD / embed69 (relay Cloudflare Worker) ───────────────────────
# EMBED69_RELAY_URL=https://TU-WORKER-EMBED69.workers.dev
# EMBED69_RELAY_KEY=       (opcional; si defines RELAY_KEY en el Worker)
# En Render usa relay automático si RENDER está definido y EMBED69_RELAY_URL existe.

# URL pública del API — OBLIGATORIA en producción (Render/WebOS) para proxy HLS.
# Sin esto, wrapStreamUrl usaría localhost y el reproductor en TV no podrá cargar segmentos.
# NEXUS_PUBLIC_URL=https://nexusmedia-1mpl.onrender.com