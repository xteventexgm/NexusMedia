# ── Servidor ──────────────────────────────────────────────────────────────
# Render inyecta PORT automáticamente. En local puedes usar 3000.
PORT=3000
# Alias legacy (Electron local). PORT tiene prioridad.
# NEXUS_API_PORT=3000

# Escuchar en todas las interfaces (requerido para Docker/Render)
HOST=0.0.0.0

NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────
# Uso personal: * permite WebOS, Electron, Android y navegadores.
# Producción restrictiva: https://tu-app.onrender.com,http://localhost:5173
CORS_ORIGIN=*

# ── TMDB (enriquecimiento de metadatos — opcional) ───────────────────────
# Obtén credenciales en https://www.themoviedb.org/settings/api
TMDB_API_KEY=
TMDB_READ_TOKEN=

# ── Datos persistentes (caché TV, etc.) ───────────────────────────────────
# En Docker/Render usa un path escribible o monta un volumen en este directorio.
NEXUS_DATA_DIR=./data

# ── Timeouts y caché ──────────────────────────────────────────────────────
HTTP_TIMEOUT_MS=20000
HOME_CACHE_TTL_MS=300000
TV_CACHE_TTL_MS=43200000

# ── DoramasFlix (GraphQL) ───────────────────────────────────────────────────
# Sitio: https://doramasflix.in/
# API GraphQL real (la usa el frontend de doramasflix.in):
# DORAMASFLIX_API_URL=https://sv1.fluxcedene.net/api/gql
# DORAMASFLIX_SITE_URL=https://doramasflix.in
# Timeout y reintentos (Render suele necesitar más tiempo)
DORAMASFLIX_TIMEOUT_MS=30000
DORAMASFLIX_RETRIES=3
# Si Render bloquea la IP, usa un proxy HTTP/HTTPS residencial:
# DORAMASFLIX_PROXY=http://usuario:pass@host:puerto
# HTTPS_PROXY=http://usuario:pass@host:puerto

# ── Relay DoramasFlix (Render → Docker local) ─────────────────────────────
# La API bloquea IPs de datacenter (Render). Docker Desktop en tu PC sí funciona.
#
# PASO 1 — En tu PC (Docker local), expón el relay:
#   DORAMAS_RELAY_ENABLED=true
#   DORAMAS_RELAY_KEY=una_clave_secreta_larga
#   Usa ngrok / Cloudflare Tunnel para exponer :3000 → https://tu-casa.example.com
#
# PASO 2 — En Render, redirige DoramasFlix por tu PC:
#   DORAMASFLIX_RELAY_URL=https://tu-casa.example.com/api/relay/doramas-gql
#   DORAMASFLIX_RELAY_KEY=una_clave_secreta_larga
#
# Alternativa más simple: apunta WebOS directamente a tu Docker local (sin Render).

# URL base del scraper DoramasLatinoX (opcional)
# DORAMASLATINOX_URL=https://doramaslatinox.com

# URL pública del API (requerida para proxy HLS en WebOS / Railway)
# Railway: https://tu-app.up.railway.app
# Render:   https://tu-app.onrender.com
NEXUS_PUBLIC_URL=https://nexusmedia-1mpl.onrender.com
DORAMASFLIX_RELAY_URL=